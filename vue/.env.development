# 页面标题
VITE_APP_TITLE = 校园流浪猫狗管理平台

# 开发环境配置
VITE_APP_ENV = 'development'

# 后台管理端/开发环境
# 使用 /dev-api 让 Vite 代理到后端（局域网部署时无需改这里）
# 实际后端地址在 vite.config.js 的 proxy.target 中配置
VITE_APP_BASE_API = '/dev-api'

# Vite 代理访问的后端。前后端在同一台电脑启动时保持 localhost 即可，
# 其他局域网设备访问前端时，请求仍由这台电脑上的 Vite 代理转发。
VITE_BACKEND_TARGET = 'http://localhost:8080'
